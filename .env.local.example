# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Agent Treasury ─────────────────────────────────────────────────────────────
# The wallet address that RECEIVES 0.01 USDC payments from users
# Replace with your own Arc testnet wallet address
NEXT_PUBLIC_AGENT_TREASURY=0xYourWalletAddressHere

# ── Site URL (for Open Graph / social share cards) ────────────────────────────
# Set this to your deployed Vercel URL (or custom domain) after deploying.
# Not required for local dev, defaults to https://tollgate.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-deployment-url.vercel.app

# ── (Optional) ERC-20 USDC contract ───────────────────────────────────────────
# Arc uses USDC as its native gas token, so this is usually NOT needed.
# Only set this if you specifically need to call a wrapped/ERC-20 USDC contract.
# NEXT_PUBLIC_USDC_CONTRACT_ADDRESS=
